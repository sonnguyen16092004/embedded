#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node* next;
};

// in danh sách
void display(struct node* head)
{
    while (head != NULL)
    {
        printf("%d -> ", head->data);
        head = head->next;
    }
    printf("NULL\n");
}

int main()
{
    // tạo list thủ công
    struct node* n1 = malloc(sizeof(struct node));
    struct node* n2 = malloc(sizeof(struct node));

    n1->data = 10; n1->next = n2;
    n2->data = 20; n2->next = NULL;

    display(n1);

    free(n1);
    free(n2);
    return 0;
}
