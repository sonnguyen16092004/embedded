#include <stdio.h>
#include <stdlib.h>

struct tnode {
    int data;
    struct tnode* left;
    struct tnode* right;
};

struct tnode* talloc(int data)
{
    struct tnode* node = (struct tnode*)malloc(sizeof(struct tnode));
    node->data = data;
    node->left = NULL;
    node->right = NULL;
    return node;
}

// thêm node vào BST
struct tnode* addnode(struct tnode* root, int data)
{
    if (root == NULL)
        return talloc(data);

    if (data < root->data)
        root->left = addnode(root->left, data);
    else
        root->right = addnode(root->right, data);

    return root;
}

// in inorder để kiểm tra
void inorder(struct tnode* root)
{
    if (root == NULL) return;

    inorder(root->left);
    printf("%d ", root->data);
    inorder(root->right);
}

int main()
{
    struct tnode* root = NULL;

    int arr[] = {3, 1, 0, 2, 8, 6, 5, 9};
    int n = 8;

    for (int i = 0; i < n; i++)
        root = addnode(root, arr[i]);

    printf("Inorder (sorted): ");
    inorder(root);

    return 0;
}
